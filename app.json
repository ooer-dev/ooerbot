{
  "name": "OoerBot",
  "repository": "https://github.com/ooer-dev/ooerbot",
  "env": {
    "LOG_LEVEL": {
      "description": "Log level of application",
      "value": "INFO"
    },
    "DISCORD_TOKEN": {
      "description": "Bot token generated by Discord for authentication"
    },
    "ADMIN_USER_IDS": {
      "description": "Comma-separated list of Discord User IDs that have ownership of the bot",
      "value": "174640149999779840"
    },
    "POETRY_VERSION": "1.1.7",
    "PYTHON_RUNTIME_VERSION": "3.9.6"
  },
  "formation": {
    "worker": {
      "quantity": 1,
      "size": "hobby"
    }
  },
  "addons": [
    "papertrail"
  ],
  "buildpacks": [
    {
      "url": "https://github.com/moneymeets/python-poetry-buildpack.git"
    },
    {
      "url": "heroku/python"
    }
  ]
}
